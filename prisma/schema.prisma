generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  role                String               @default("student")
  membership          String               @default("free")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  paymentSlips        PaymentSlip[]
  paymentTransactions PaymentTransaction[]
  lessonProgress      LessonProgress[]
  notifications       UserNotification[]
  courseAccesses      UserCourseAccess[]
}

model LessonProgress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  Int
  completed Boolean  @default(false)
  quizScore Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model PaymentSlip {
  id          String    @id @default(cuid())
  userId      String
  amount      Int
  productType String    @default("premium")
  imageUrl    String
  note        String?
  status      String    @default("pending")
  adminNote   String?
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([productType])
}

model UserCourseAccess {
  id         String   @id @default(cuid())
  userId     String
  courseSlug String
  grantedBy  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseSlug])
  @@index([userId])
  @@index([courseSlug])
}

model LiveSession {
  id             String   @id @default(cuid())
  title          String
  description    String?
  youtubeVideoId String
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
  @@index([updatedAt])
}

model PaymentTransaction {
  id               String    @id @default(cuid())
  userId           String
  provider         String    @default("omise")
  providerChargeId String?   @unique
  providerEventId  String?   @unique
  amount           Int
  currency         String    @default("THB")
  status           String    @default("pending")
  paymentMethod    String    @default("promptpay_gateway")
  qrCodeUrl        String?
  failureCode      String?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model UserNotification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  link      String?
  type      String    @default("admin_broadcast")
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}
